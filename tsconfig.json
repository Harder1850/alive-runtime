{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": "../",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "../alive-mind/src/**/*.ts",
    "../alive-body/src/**/*.ts",
    "../alive-constitution/contracts/**/*.ts",
    "../alive-constitution/invariants/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "../**/node_modules", "../**/dist"]
}
